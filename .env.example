# ── LLM Providers ──────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here
GEMINI_API_KEY=your_gemini_key_here

# Default provider: claude | openai | gemini
DEFAULT_PROVIDER=claude
# Default model per provider (auto-selected if blank)
DEFAULT_MODEL=

# ── Search Sources ──────────────────────────────────────────
TAVILY_API_KEY=your_tavily_key_here
SERPER_API_KEY=your_serper_key_here
# ArXiv needs no key — public API

# ── Database (Vault + Reputation Graph) ────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/deep_research
# Cloud sync (optional — leave blank to disable)
CLOUD_SYNC_URL=

# ── Vault Settings ──────────────────────────────────────────
VAULT_LOCAL_PATH=./vault
VAULT_AUTO_SYNC=false

# ── Reputation Graph ────────────────────────────────────────
# Minimum score before blacklist warning
BLACKLIST_WARN_THRESHOLD=20
# Score below this triggers auto-blacklist after user confirms
BLACKLIST_AUTO_THRESHOLD=10

# ── Source Trust Scores (initial defaults) ──────────────────
# These seed the reputation graph on first run
TRUST_SEED_EDU=90
TRUST_SEED_GOV=85
TRUST_SEED_ORG=70
TRUST_SEED_COM=50
TRUST_SEED_DEFAULT=40
